# =============================================================================
# Legal Contract Automation Suite - Environment Configuration
# =============================================================================

# Required: Google Gemini API Key (primary LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (fallback provider)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic API Key (alternative fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Pinecone API Key (for vector store)
PINECONE_API_KEY=your_pinecone_api_key_here

# Optional: Tavily API Key (for web search in legal research)
TAVILY_API_KEY=your_tavily_api_key_here

# =============================================================================
# Model Configuration
# =============================================================================
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
LLM_LITE_MODEL=gemini-2.5-flash-lite
EMBEDDING_MODEL=models/gemini-embedding-2

# =============================================================================
# Cache Configuration (cost optimization)
# =============================================================================
CACHE_TTL_SECONDS=300

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
DEBUG=false
